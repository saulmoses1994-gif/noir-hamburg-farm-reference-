# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
# Commit only the per-service/-area SSG output as a deploy safety net so
# production always has route-specific HTML even if `yarn build` doesn't run
# to completion. Everything else in build/ stays ignored.
/build/*
!/build/services
!/build/services/**
!/build/escort
!/build/escort/**
!/build/index.html

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
